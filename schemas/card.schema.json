{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MicrocardRecord",
  "description": "A how-to microcard distilled from tests/vignettes/examples",
  "type": "object",
  "required": ["id", "language", "q", "a", "recipe", "symbols", "sources"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+::howto/[a-z0-9_-]+$",
      "description": "Stable ID: pkg::howto/<slug>"
    },
    "language":  { "type": "string", "enum": ["R", "Python"] },
    "q":         { "type": "string", "description": "How do I …? question (seed)" },
    "a": {
      "type": "string",
      "minLength": 40,
      "maxLength": 600,
      "description": "Answer paragraph (40-100 words)"
    },
    "recipe": {
      "type": "string",
      "description": "Code snippet (3-15 lines)"
    },
    "symbols": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9._-]+::[A-Za-z0-9._]+$" },
      "description": "Symbols referenced (pkg::fn)"
    },
    "tags":    { "type": "array", "items": { "type": "string" } },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "lines"],
        "properties": {
          "path":  { "type": "string" },
          "lines": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
